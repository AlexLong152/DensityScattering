        RowBox[{"Abs", "[", "m1", "]"}], "<=", "j1"}], "&&", 
       RowBox[{
        RowBox[{"Abs", "[", "m2", "]"}], "<=", "j2"}], "&&", 
       RowBox[{"j", ">=", 
        RowBox[{"Abs", "[", 
         RowBox[{"j1", "-", "j2"}], "]"}]}], "&&", 
       RowBox[{"j", "<=", 
        RowBox[{"j1", "+", "j2"}]}], "&&", 
       RowBox[{"IntegerQ", "[", 
        RowBox[{"j1", "+", "j2", "+", "j"}], "]"}]}], 
      RowBox[{"(*", 
