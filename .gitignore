#This is a centralised file to ignore certain type of files
#This means each clone of the repo will follow these instructions
#If you wish to exclude something from your specific repo, use
#.git/info/exclude

# Build artifacts
*.[oa]
*~
*.mod
*.tmp
*.pdf
*.gz
*.log

# LaTeX artifacts
*.aux
*.fls
*.fdb_latexmk
*.out
*.toc
*.synctex.gz

# Fortran scratch files
fort.*

# Profiling output
gmon.out

# Local config
.gitconfig

# Python
__pycache__/
tmp.py

# Generated input/output files
.pyinput-*
.pyinput.dat
.pCommand.sh
input-*.dat
test-*.dat
output*.dat
out*.dat
save-out*.dat
.output-*.dat
*.dat-benchmark

# Compiled executables (match only files, not directories)
# The onebodyvia1Ndensity and twobodyvia2Ndensity directories contain source code,
# but each *.onebody/ and *.twobody/ folder may have a compiled binary of the same name.
PionPhotoProd.onebody/onebodyvia1Ndensity
PionPhotoProdThresh.onebody/onebodyvia1Ndensity
PionPion.onebody/onebodyvia1Ndensity
varsub-PionPion.twobody/twobodyvia2Ndensity.PionPion
varsub-PionPhotoProdThresh.twobody/twobodyvia2Ndensity.PionPhotoProdThresh
common-densities/density-modules/testcompdens
common-densities/varsub-density-modules/testcompdens
common-densities/2Ndensity-module/testcompdens
onebodyvia1Ndensity/onebodyvia1Ndensity
twobodyvia2Ndensity/twobodyvia2Ndensity
tests/sigmaYcheck/sigmaYCheck
testGetCS
tesetGetMat

# Literature/reference PDFs (local only)
lit/
lit/*
Braun-subset.pdf
documentation/poles-pionphotoprod/Transfer_PiPh_Rijneveen.zip

# Documentation: re-include figure dependencies and compiled writeup PDFs
# (overrides the global *.pdf rule above)
!documentation/PionScattering/writeup/*.pdf
!documentation/PionPhotoProduction/Kernel/figs/*.pdf
!documentation/PionPhotoProduction/Kernel/pionphoto-kernel.pdf
!documentation/twobody-documentation/twobody-structure-integrations-and-units.20240331.pdf

# Density data files
densities-*/*/1Ndensities/*.dat
densities-*/*/1Ndensities/*/*.dat
densities-*/*/1Ndensities/*/*/*.dat
densities-*/*/1Ndensities/*/*/*/*.dat
densities-*/*/1Ndensities/*/*/*/*/*.dat
onebodyvia1Ndensity/*.dat
twobodyvia2Ndensity/*.dat

# Input/output folders in onebodyvia1Ndensity/, twobodyvia2Ndensity/
onebodyvia1Ndensity/input*/*
!onebodyvia1Ndensity/input*/template*
onebodyvia1Ndensity/output*/*
twobodyvia2Ndensity/input*/*
!twobodyvia2Ndensity/input*/template*
twobodyvia2Ndensity/output*/*

# Output/results/test directories
results*/
**/outputs/
**/outs/
**/FinalResults/
**/testDiags/
**/old/
**/backup-*/

# Working directories
.claude/
*-play/
workinprogress/

# Local credentials/scripts
/git-token
/github-commands

# Specific legacy ignores
/PionPhotoProdThresh.twobody/PHYSICAL-output.dat
/PionPhotoProdThresh.twobody/TESTING-output.dat
/PionPhotoProdThresh.twobody/physicalInput.dat
/PionPhotoProdThresh.twobody/testInput.dat
/PionPhotoProdThresh.twobody/twobodyvia2Ndensity.PionPhotoProdThresh
/PionPhotoProdThresh.twobody/test-twobody-*.dat
/documentation/twobody-documentation/twobody-structure-integrations-and-units.20240331.out
/documentation/twobody-documentation/twobody-structure-integrations-and-units.20240331.toc
/documentation/twobody-documentation/figuresfeyn.mp

# Report/summary files (historical debugging notes)
**/summary/
**/normReport.md
**/details/
